BOT_TOKEN=
STAFF_GROUP_CHAT_ID=-1001234567890
ADMIN_USER_IDS=123456789,987654321

# Async + sync DSN (Fly Managed Postgres)
SQLALCHEMY_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
SQLALCHEMY_DATABASE_URL_SYNC_DRIVER=postgresql+psycopg://user:pass@host:5432/dbname

LOCAL_RUN=false
ECHO_SQLALCHEMY=false

# One of: path to YAML or JSON in env
DEPARTMENTS_FILE=config/departments.yaml
# DEPARTMENTS_JSON={"departments":[{"name":"IT","thread_id":3}]}

# KPI export (optional): share the sheet with the service account email from the JSON key
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=
